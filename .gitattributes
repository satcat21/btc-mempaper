# Enforce LF line endings for all text files — this project runs on Linux/Raspberry Pi
* text=auto eol=lf

# Shell scripts must always be LF (CRLF breaks bash on Linux)
*.sh text eol=lf

# Source files
*.py   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Config / system files deployed to Linux
*.rules   text eol=lf
*.service text eol=lf
*.conf    text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.woff  binary
*.woff2 binary
