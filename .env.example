# mempaper environment configuration
# Copy this file to .env and adjust values as needed.
# The .env file is ignored by git and never committed.

# Optional: API token for fetching release notes from private Git repositories.
# Without this, the updater falls back to local git tags (updates still work,
# but release notes won't be shown in the web UI).
#
# GitHub: Personal Access Token with "repo" scope
#   https://github.com/settings/tokens
#
# GitLab: Personal Access Token with "read_api" scope
#   https://<your-gitlab>//-/user_settings/personal_access_tokens
#
# GIT_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GIT_API_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
